---
import { Icon } from "astro-icon/components";
import { getSiteLocale, siteCopy } from "@/i18n";

const locale = getSiteLocale(Astro.url.pathname);
const featureCopy = siteCopy[locale].features;
const featureArt = [
  {
    icon: "bx:bx-cloud",
    accent: "storage",
  },
  {
    icon: "bx:bxs-bot",
    accent: "agent",
  },
  {
    icon: "bx:bx-layout",
    accent: "workspace",
  },
  {
    icon: "bx:bx-transfer",
    accent: "open",
  },
  {
    icon: "bx:bx-shield-quarter",
    accent: "secure",
  },
  {
    icon: "bx:bx-group",
    accent: "accounts",
  },
];

const features = featureCopy.items.map((item, index) => ({ ...item, ...featureArt[index] }));
---

<section class="mt-8 md:mt-12 relative overflow-hidden" aria-labelledby="features">
  <div class="absolute top-32 -left-24 w-72 h-72 bg-brand-border/10 rounded-full blur-3xl -z-10"></div>
  <div class="absolute bottom-24 -right-24 w-72 h-72 bg-slate-200/30 rounded-full blur-3xl -z-10"></div>

  <div class="max-w-3xl mb-14 text-center mx-auto">
    <h2 class="text-4xl lg:text-5xl font-bold text-slate-900" id="features">
      {featureCopy.heading}
    </h2>
  </div>

  <div class="space-y-6">
    {
      features.map((feature) => (
        <article class="group relative overflow-hidden rounded-[28px] border border-slate-200 bg-white shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-brand-border hover:shadow-[0_22px_55px_-35px_rgb(var(--edgeever-brand-rgb)/0.55)]">
          <div class="grid h-[800px] grid-cols-1 sm:h-[760px] md:h-[700px] lg:h-[460px] lg:grid-cols-[minmax(0,1.02fr)_minmax(360px,0.98fr)]">
            <div class="flex h-full flex-col justify-center p-7 sm:p-9 lg:p-10">
              <div class="mb-7 flex items-center gap-4">
                <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl border border-brand-border/40 bg-brand-soft text-brand-text shadow-sm">
                  <Icon name={feature.icon} class="h-7 w-7" />
                </div>
              </div>

              <h3 class="text-2xl font-bold leading-tight text-slate-900 sm:text-3xl">
                {feature.title}
              </h3>
              <p class="mt-4 max-w-2xl text-base leading-8 text-slate-600">
                {feature.summary}
              </p>

              <ul class="mt-7 grid gap-3">
                {feature.points.map((point) => (
                  <li class="flex gap-3 text-sm leading-6 text-slate-600 sm:text-base">
                    <span class="mt-1 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-brand-muted text-brand-text">
                      <Icon name="bx:bx-check" class="h-3.5 w-3.5" />
                    </span>
                    <span>{point}</span>
                  </li>
                ))}
              </ul>
            </div>

            <div class="relative min-h-[220px] overflow-hidden border-t border-slate-100 bg-slate-50/70 md:min-h-full lg:border-l lg:border-t-0">
              <div class={`feature-art feature-art-${feature.accent}`} aria-hidden="true">
                {feature.accent === "storage" && (
                  <div class="storage-scene">
                    <div class="storage-cloud">
                      <Icon name="bx:bx-cloud" class="h-14 w-14" />
                    </div>
                    <div class="storage-meter">
                      <span>Cloudflare</span>
                      <strong>15w+</strong>
                      <i></i>
                    </div>
                    <div class="storage-stack storage-stack-d1">
                      <span>D1</span>
                      <b></b>
                      <b></b>
                      <b></b>
                    </div>
                    <div class="storage-stack storage-stack-r2">
                      <span>R2</span>
                      <b></b>
                      <b></b>
                      <b></b>
                    </div>
                    <div class="storage-gallery">
                      <i></i>
                      <i></i>
                      <i></i>
                      <i></i>
                    </div>
                  </div>
                )}

                {feature.accent === "agent" && (
                  <div class="agent-scene">
                    <div class="agent-orbit"></div>
                    <div class="agent-center">
                      <Icon name="bx:bxs-bot" class="h-12 w-12" />
                    </div>
                    <div class="agent-node agent-node-mcp">
                      <Icon name="bx:bx-plug" class="h-6 w-6" />
                      <span>MCP</span>
                    </div>
                    <div class="agent-node agent-node-api">
                      <Icon name="bx:bx-code-alt" class="h-6 w-6" />
                      <span>API</span>
                    </div>
                    <div class="agent-node agent-node-doc">
                      <Icon name="bx:bx-file" class="h-6 w-6" />
                      <span>OpenAPI</span>
                    </div>
                    <div class="agent-node agent-node-note">
                      <Icon name="bx:bx-note" class="h-6 w-6" />
                      <span>Notes</span>
                    </div>
                  </div>
                )}

                {feature.accent === "workspace" && (
                  <div class="workspace-scene">
                    <div class="workspace-window">
                      <div class="workspace-topbar">
                        <span></span>
                        <span></span>
                        <span></span>
                      </div>
                      <div class="workspace-body">
                        <div class="workspace-pane workspace-tree">
                          <b></b>
                          <i></i>
                          <i></i>
                          <i></i>
                          <i></i>
                        </div>
                        <div class="workspace-pane workspace-list">
                          <b></b>
                          <strong></strong>
                          <strong></strong>
                          <strong></strong>
                        </div>
                        <div class="workspace-pane workspace-editor">
                          <b></b>
                          <i></i>
                          <i></i>
                          <em></em>
                          <i></i>
                        </div>
                      </div>
                    </div>
                  </div>
                )}

                {feature.accent === "open" && (
                  <div class="open-scene">
                    <div class="open-doc open-markdown">
                      <span>Markdown</span>
                      <b># Note</b>
                      <i></i>
                      <i></i>
                      <i></i>
                    </div>
                    <div class="open-doc open-json">
                      <span>JSON</span>
                      <b>{"{ }"}</b>
                      <i></i>
                      <i></i>
                    </div>
                    <div class="open-export">
                      <Icon name="bx:bx-export" class="h-8 w-8" />
                    </div>
                    <div class="open-chips">
                      <em>API</em>
                      <em>MCP</em>
                      <em>CLI</em>
                    </div>
                    <div class="open-zip">
                      <Icon name="bx:bx-archive" class="h-5 w-5" />
                      <span>EdgeEver ZIP</span>
                    </div>
                  </div>
                )}

                {feature.accent === "secure" && (
                  <div class="secure-scene">
                    <div class="secure-link secure-link-desktop"></div>
                    <div class="secure-link secure-link-phone"></div>
                    <div class="secure-desktop">
                      <div class="secure-topbar">
                        <b></b>
                        <b></b>
                        <b></b>
                      </div>
                      <i></i>
                      <i></i>
                      <i></i>
                    </div>
                    <div class="secure-phone">
                      <span></span>
                      <i></i>
                      <i></i>
                    </div>
                    <div class="secure-sync">
                      <Icon name="bx:bx-sync" class="h-10 w-10" />
                      <span>Sync</span>
                    </div>
                    <div class="secure-queue">
                      <Icon name="bx:bx-wifi-off" class="h-5 w-5" />
                      <span>Offline queue</span>
                    </div>
                    <div class="secure-status">
                      <Icon name="bx:bx-check" class="h-4 w-4" />
                      <span>Auto saved</span>
                    </div>
                  </div>
                )}

                {feature.accent === "accounts" && (
                  <div class="accounts-scene">
                    <div class="accounts-instance">
                      <Icon name="bx:bx-cloud" class="h-8 w-8" />
                      <span>One instance</span>
                    </div>
                    <div class="accounts-link accounts-link-owner"></div>
                    <div class="accounts-link accounts-link-left"></div>
                    <div class="accounts-link accounts-link-right"></div>
                    <div class="account-card account-owner">
                      <span class="account-avatar"><Icon name="bx:bx-crown" class="h-5 w-5" /></span>
                      <strong>Owner</strong>
                      <small>Private workspace</small>
                    </div>
                    <div class="account-card account-member-left">
                      <span class="account-avatar"><Icon name="bx:bx-user" class="h-5 w-5" /></span>
                      <strong>Member</strong>
                      <small>Private workspace</small>
                    </div>
                    <div class="account-card account-member-right">
                      <span class="account-avatar"><Icon name="bx:bx-user" class="h-5 w-5" /></span>
                      <strong>Member</strong>
                      <small>Private workspace</small>
                    </div>
                    <div class="accounts-token">
                      <Icon name="bx:bx-key" class="h-5 w-5" />
                      <span>Isolated MCP tokens</span>
                    </div>
                  </div>
                )}
              </div>
            </div>
          </div>
        </article>
      ))
    }
  </div>
</section>

<style>
  .feature-art {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    padding: 28px;
    isolation: isolate;
  }

  .feature-art::before {
    content: "";
    position: absolute;
    inset: 10%;
    border-radius: 999px;
    background:
      radial-gradient(circle at 35% 30%, rgb(var(--edgeever-brand-rgb) / 0.18), transparent 34%),
      radial-gradient(circle at 75% 72%, rgb(15 23 42 / 0.08), transparent 36%);
    filter: blur(18px);
  }

  .feature-art > * {
    position: relative;
    z-index: 1;
  }

  .storage-scene,
  .agent-scene,
  .workspace-scene,
  .open-scene,
  .secure-scene,
  .accounts-scene {
    width: min(88%, 460px);
    aspect-ratio: 1.28;
  }

  .storage-cloud,
  .storage-meter,
  .storage-stack,
  .storage-gallery,
  .agent-center,
  .agent-node,
  .workspace-window,
  .open-doc,
  .open-export,
  .open-chips,
  .open-zip,
  .secure-desktop,
  .secure-phone,
  .secure-sync,
  .secure-queue,
  .secure-status {
    position: absolute;
    border: 1px solid rgb(203 213 225 / 0.72);
    background: rgb(255 255 255 / 0.86);
    box-shadow: 0 18px 60px -42px rgb(15 23 42 / 0.8);
    backdrop-filter: blur(12px);
  }

  .storage-scene {
    transform: rotate(-2deg);
    transition: transform 300ms ease;
  }

  .group:hover .storage-scene,
  .group:hover .agent-scene,
  .group:hover .workspace-window,
  .group:hover .open-scene,
  .group:hover .secure-scene {
    transform: translateY(-4px);
  }

  .storage-cloud {
    top: 10%;
    left: 50%;
    display: grid;
    width: 122px;
    height: 122px;
    place-items: center;
    translate: -50% 0;
    border-radius: 36px;
    color: var(--edgeever-brand-text);
    background:
      radial-gradient(circle at 30% 25%, rgb(var(--edgeever-brand-rgb) / 0.18), transparent 44%),
      rgb(255 255 255 / 0.9);
  }

  .storage-meter {
    top: 6%;
    right: 2%;
    display: grid;
    gap: 5px;
    width: 136px;
    padding: 16px;
    border-radius: 22px;
  }

  .storage-meter span,
  .storage-stack span,
  .open-doc span,
  .secure-queue span {
    font-size: 12px;
    font-weight: 700;
    color: var(--edgeever-brand-text);
  }

  .storage-meter strong {
    font-size: 28px;
    line-height: 1;
    color: #0f172a;
  }

  .storage-meter i {
    display: block;
    height: 8px;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--edgeever-brand), rgb(203 213 225 / 0.7));
  }

  .storage-stack {
    bottom: 7%;
    display: grid;
    gap: 7px;
    width: 142px;
    padding: 16px;
    border-radius: 24px;
  }

  .storage-stack-d1 {
    left: 4%;
  }

  .storage-stack-r2 {
    right: 4%;
  }

  .storage-stack b {
    display: block;
    height: 12px;
    border-radius: 999px;
    background: rgb(148 163 184 / 0.42);
  }

  .storage-stack b:nth-of-type(2) {
    width: 76%;
    background: rgb(var(--edgeever-brand-rgb) / 0.32);
  }

  .storage-gallery {
    left: 50%;
    bottom: 20%;
    display: grid;
    grid-template-columns: repeat(2, 54px);
    gap: 10px;
    padding: 12px;
    translate: -50% 0;
    border-radius: 24px;
    background: rgb(248 250 252 / 0.76);
  }

  .storage-gallery i {
    display: block;
    width: 54px;
    height: 42px;
    border-radius: 14px;
    background:
      linear-gradient(135deg, rgb(var(--edgeever-brand-rgb) / 0.24), transparent),
      rgb(226 232 240 / 0.72);
  }

  .agent-scene {
    transition: transform 300ms ease;
  }

  .agent-orbit {
    position: absolute;
    inset: 12%;
    border: 1px dashed rgb(var(--edgeever-brand-rgb) / 0.38);
    border-radius: 999px;
  }

  .agent-orbit::before,
  .agent-orbit::after {
    content: "";
    position: absolute;
    background: rgb(var(--edgeever-brand-rgb) / 0.35);
  }

  .agent-orbit::before {
    top: 50%;
    left: -4%;
    width: 108%;
    height: 1px;
  }

  .agent-orbit::after {
    top: -4%;
    left: 50%;
    width: 1px;
    height: 108%;
  }

  .agent-center {
    top: 50%;
    left: 50%;
    display: grid;
    width: 118px;
    height: 118px;
    place-items: center;
    translate: -50% -50%;
    border-radius: 999px;
    color: var(--edgeever-brand-text);
  }

  .agent-node {
    display: grid;
    gap: 6px;
    width: 112px;
    height: 86px;
    place-items: center;
    border-radius: 24px;
    color: var(--edgeever-brand-text);
    font-size: 12px;
    font-weight: 800;
  }

  .agent-node-mcp {
    top: 2%;
    left: 8%;
  }

  .agent-node-api {
    top: 8%;
    right: 4%;
  }

  .agent-node-doc {
    bottom: 7%;
    left: 6%;
  }

  .agent-node-note {
    right: 8%;
    bottom: 2%;
  }

  .workspace-scene {
    width: min(90%, 500px);
  }

  .workspace-window {
    inset: 5% 0 7%;
    overflow: hidden;
    border-radius: 24px;
    transition: transform 300ms ease;
  }

  .workspace-topbar {
    display: flex;
    gap: 8px;
    align-items: center;
    height: 44px;
    padding: 0 18px;
    border-bottom: 1px solid rgb(226 232 240 / 0.84);
  }

  .workspace-topbar span,
  .secure-topbar b {
    width: 9px;
    height: 9px;
    border-radius: 999px;
    background: #cbd5e1;
  }

  .workspace-body {
    display: grid;
    grid-template-columns: 28% 32% 1fr;
    height: calc(100% - 44px);
  }

  .workspace-pane {
    display: grid;
    align-content: start;
    gap: 12px;
    padding: 20px 16px;
  }

  .workspace-tree,
  .workspace-list {
    border-right: 1px solid rgb(226 232 240 / 0.78);
    background: rgb(248 250 252 / 0.72);
  }

  .workspace-pane b,
  .workspace-pane i,
  .workspace-pane strong,
  .workspace-pane em,
  .secure-desktop i,
  .secure-phone i,
  .open-doc i {
    display: block;
    border-radius: 999px;
  }

  .workspace-pane b {
    width: 70%;
    height: 15px;
    background: rgb(15 23 42 / 0.66);
  }

  .workspace-pane i,
  .open-doc i,
  .secure-desktop i,
  .secure-phone i {
    height: 11px;
    background: rgb(148 163 184 / 0.42);
  }

  .workspace-tree i:nth-child(3),
  .workspace-list strong:nth-child(3),
  .workspace-editor i:nth-child(3) {
    background: rgb(var(--edgeever-brand-rgb) / 0.32);
  }

  .workspace-list strong {
    height: 54px;
    border-radius: 16px;
    background: rgb(226 232 240 / 0.58);
  }

  .workspace-editor em {
    height: 88px;
    border-radius: 18px;
    background:
      linear-gradient(135deg, rgb(var(--edgeever-brand-rgb) / 0.22), transparent),
      rgb(241 245 249 / 0.92);
  }

  .open-scene {
    transform: rotate(1deg);
    transition: transform 300ms ease;
  }

  .open-doc {
    display: grid;
    gap: 12px;
    padding: 20px;
    border-radius: 24px;
  }

  .open-markdown {
    top: 4%;
    left: 2%;
    width: 210px;
    height: 245px;
    rotate: -5deg;
  }

  .open-json {
    right: 4%;
    bottom: 5%;
    width: 188px;
    height: 210px;
    rotate: 5deg;
  }

  .open-doc b {
    font-size: 26px;
    line-height: 1;
    color: #0f172a;
  }

  .open-doc i:nth-of-type(2) {
    width: 72%;
    background: rgb(var(--edgeever-brand-rgb) / 0.34);
  }

  .open-export {
    top: 50%;
    left: 50%;
    display: grid;
    width: 86px;
    height: 86px;
    place-items: center;
    translate: -50% -50%;
    border-radius: 999px;
    color: var(--edgeever-brand-text);
  }

  .open-export::before,
  .open-export::after {
    content: "";
    position: absolute;
    top: 50%;
    width: 112px;
    height: 2px;
    background: linear-gradient(90deg, transparent, rgb(var(--edgeever-brand-rgb) / 0.36), transparent);
  }

  .open-export::before {
    right: 78px;
  }

  .open-export::after {
    left: 78px;
  }

  .open-chips {
    left: 50%;
    bottom: 0;
    display: flex;
    gap: 8px;
    padding: 10px;
    translate: -50% 0;
    border-radius: 999px;
  }

  .open-chips em {
    padding: 7px 12px;
    border-radius: 999px;
    background: rgb(var(--edgeever-brand-rgb) / 0.1);
    color: var(--edgeever-brand-text);
    font-size: 12px;
    font-style: normal;
    font-weight: 800;
  }

  .open-zip {
    top: 1%;
    right: 3%;
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 10px 14px;
    border-radius: 999px;
    color: var(--edgeever-brand-text);
  }

  .open-zip span {
    font-size: 12px;
    font-weight: 800;
  }

  .secure-scene {
    transition: transform 300ms ease;
  }

  .secure-link {
    position: absolute;
    z-index: 0;
    height: 2px;
    border-radius: 999px;
    background: repeating-linear-gradient(
      90deg,
      rgb(var(--edgeever-brand-rgb) / 0.42) 0 10px,
      transparent 10px 18px
    );
  }

  .secure-link-desktop {
    top: 47%;
    left: 28%;
    width: 160px;
    rotate: 8deg;
  }

  .secure-link-phone {
    top: 55%;
    right: 18%;
    width: 130px;
    rotate: -18deg;
  }

  .secure-desktop {
    top: 10%;
    left: 6%;
    width: 310px;
    height: 210px;
    overflow: hidden;
    border-radius: 24px;
  }

  .secure-topbar {
    display: flex;
    gap: 8px;
    align-items: center;
    height: 42px;
    padding: 0 16px;
    border-bottom: 1px solid rgb(226 232 240 / 0.84);
  }

  .secure-desktop i {
    margin: 20px 24px 0;
    height: 13px;
  }

  .secure-desktop i:nth-of-type(1) {
    width: 72%;
    background: rgb(15 23 42 / 0.64);
  }

  .secure-desktop i:nth-of-type(2) {
    width: 54%;
    background: rgb(var(--edgeever-brand-rgb) / 0.32);
  }

  .secure-desktop i:nth-of-type(3) {
    width: 82%;
  }

  .secure-phone {
    right: 5%;
    bottom: 8%;
    display: grid;
    align-content: start;
    gap: 14px;
    width: 122px;
    height: 220px;
    padding: 22px 16px;
    border-radius: 30px;
  }

  .secure-phone span {
    display: block;
    width: 34px;
    height: 5px;
    margin-inline: auto;
    border-radius: 999px;
    background: rgb(148 163 184 / 0.5);
  }

  .secure-phone i:nth-of-type(1) {
    margin-top: 20px;
    height: 58px;
    border-radius: 18px;
    background: rgb(var(--edgeever-brand-rgb) / 0.2);
  }

  .secure-phone i:nth-of-type(2) {
    height: 11px;
  }

  .secure-sync {
    top: 46%;
    left: 50%;
    display: grid;
    width: 112px;
    height: 112px;
    gap: 4px;
    align-content: center;
    justify-items: center;
    place-items: center;
    translate: -50% -50%;
    border-radius: 999px;
    color: var(--edgeever-brand-text);
    background:
      radial-gradient(circle at 50% 30%, rgb(var(--edgeever-brand-rgb) / 0.18), transparent 44%),
      rgb(255 255 255 / 0.92);
  }

  .secure-sync span {
    font-size: 12px;
    font-weight: 800;
    color: var(--edgeever-brand-text);
  }

  .secure-queue {
    left: 4%;
    bottom: 4%;
    display: flex;
    gap: 8px;
    align-items: center;
    padding: 13px 16px;
    border-radius: 999px;
    color: var(--edgeever-brand-text);
  }

  .secure-status {
    right: 2%;
    top: 10%;
    display: flex;
    gap: 8px;
    align-items: center;
    padding: 12px 15px;
    border-radius: 999px;
    color: var(--edgeever-brand-text);
  }

  .secure-status span {
    font-size: 12px;
    font-weight: 800;
  }

  .accounts-scene {
    transition: transform 300ms ease;
  }

  .group:hover .accounts-scene {
    transform: translateY(-4px);
  }

  .accounts-instance,
  .account-card,
  .accounts-token {
    position: absolute;
    border: 1px solid rgb(203 213 225 / 0.72);
    background: rgb(255 255 255 / 0.9);
    box-shadow: 0 18px 60px -42px rgb(15 23 42 / 0.8);
    backdrop-filter: blur(12px);
  }

  .accounts-instance {
    top: 5%;
    left: 50%;
    z-index: 2;
    display: flex;
    width: 176px;
    height: 76px;
    align-items: center;
    justify-content: center;
    gap: 10px;
    translate: -50% 0;
    border-radius: 24px;
    color: var(--edgeever-brand-text);
  }

  .accounts-instance span,
  .accounts-token span {
    font-size: 12px;
    font-weight: 800;
  }

  .accounts-link {
