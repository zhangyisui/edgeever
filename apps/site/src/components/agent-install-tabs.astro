---
import { Icon } from "astro-icon/components";

const { locale = "zh-CN" } = Astro.props;
const isEnglish = locale === "en-US";

const copy = isEnglish
  ? {
      manual: "Manual install",
      agent: "Install with AI Agent",
      agentIntro:
        "Copy the prompt below to your AI assistant (Claude Code, Codex, Cursor, Trae, and similar tools). It will complete the first installation and set up automatic updates.",
      promptLabel: "Prompt",
      copyPrompt: "Copy prompt",
      copying: "Copying...",
      copied: "Copied",
      copyFailed: "Copy failed",
      billingNotice:
        "Heads up: Cloudflare R2, D1, and Workers may ask you to add a Visa card even when you use the free quotas.",
      manualGuide: "Open the complete manual deployment guide",
      manualGuideHref: "/en/manual-deploy",
      promptText:
        "Please follow these steps:\n1. Fork the EdgeEver upstream repository: https://github.com/tianma-if/edgeever\n2. Use the forked repository to create the Cloudflare resources and complete EdgeEver's first deployment.\n3. Run `bun run deploy:builds:setup` to connect the deployed Worker to the fork's `main` branch through Cloudflare Workers Builds. Use a User API Token, not an Account API Token, when the setup requires one.\n4. After that, GitHub Sync fork or any push to `main` must automatically build, apply D1 migrations, and deploy the instance.",
    }
  : {
      manual: "手动部署",
      agent: "通过 AI Agent 部署",
      agentIntro: "将下方提示词复制给你的 AI 助手（Claude Code、Codex、Cursor、Trae 等），它会完成首次部署并配置后续自动更新。",
      promptLabel: "提示词",
      copyPrompt: "复制提示词",
      copying: "复制中...",
      copied: "已复制",
      copyFailed: "复制失败",
      billingNotice:
        "提示：Cloudflare 的 R2、D1 和 Worker 即使使用免费额度，开通或使用时也可能要求绑定 Visa 卡。国内用户可考虑使用招商银行多币种卡绑定。",
      manualGuide: "查看完整手动部署指南",
      manualGuideHref: "/manual-deploy",
      promptText:
        "请按以下流程操作：\n1. Fork EdgeEver 上游仓库：https://github.com/tianma-if/edgeever\n2. 使用 Fork 后的仓库创建 Cloudflare 资源并完成 EdgeEver 首次部署。\n3. 运行 `bun run deploy:builds:setup`，通过 Cloudflare Workers Builds 将已部署的 Worker 连接到 Fork 仓库的 `main` 分支；如需 token，使用 User API Token，不要使用 Account API Token。\n4. 后续 GitHub Sync fork 或任何推送到 `main` 的更新，都必须自动构建、执行 D1 migration 并发布该实例。",
    };
---

<section class="not-prose relative left-1/2 my-10 w-[min(92vw,960px)] -translate-x-1/2" data-agent-install-tabs>
  <div class="mx-auto flex max-w-xl items-center justify-center gap-14 border-b border-slate-200 text-lg font-semibold">
    <button
      class="agent-install-tab px-2 pb-4 text-slate-500 transition hover:text-brand-text"
      type="button"
      data-tab-target="manual"
      aria-selected="false">
      {copy.manual}
    </button>
    <button
      class="agent-install-tab active px-2 pb-4 text-brand relative transition"
      type="button"
      data-tab-target="agent"
      aria-selected="true">
      {copy.agent}
    </button>
  </div>

  <div class="mt-8 overflow-hidden rounded-[28px] bg-slate-100 px-6 py-8 sm:px-10 md:px-14">
    <div class="agent-install-panel" data-tab-panel="agent">
      <p class="mx-auto mb-8 max-w-3xl text-center text-lg leading-9 text-slate-600">
        {copy.agentIntro}
      </p>

      <div class="mx-auto max-w-3xl rounded-2xl bg-white p-6 shadow-sm">
        <p class="text-sm font-medium text-slate-400">{copy.promptLabel}</p>
        <pre class="mt-4 whitespace-pre-wrap break-words font-mono text-base leading-8 text-slate-900">{copy.promptText}</pre>
      </div>

      <div class="mt-8 flex justify-center">
        <button
          class="agent-install-copy inline-flex items-center gap-2 rounded-full bg-brand px-8 py-3 text-base font-semibold text-white shadow-[0_14px_30px_-18px_rgb(var(--edgeever-brand-rgb)/0.85)] transition hover:-translate-y-0.5 hover:bg-brand-hover"
          type="button"
          data-copy-text={copy.promptText}
          data-copy-default={copy.copyPrompt}
          data-copy-copying={copy.copying}
          data-copy-copied={copy.copied}
          data-copy-failed={copy.copyFailed}>
          <Icon class="h-5 w-5" name="bx:bx-copy" />
          <span data-copy-label>{copy.copyPrompt}</span>
        </button>
      </div>

      <div class="mx-auto mt-5 flex max-w-3xl gap-2 rounded-xl border border-amber-200/80 bg-amber-50/70 px-3 py-2 text-xs leading-5 text-amber-900">
        <Icon class="mt-0.5 h-4 w-4 shrink-0 text-amber-600" name="bx:bx-credit-card" />
        <p>{copy.billingNotice}</p>
      </div>
    </div>

    <div class="agent-install-panel hidden" data-tab-panel="manual">
      <div class="mx-auto flex justify-center">
        <a
          class="inline-flex items-center gap-2 rounded-full bg-brand px-8 py-3 text-base font-semibold text-white shadow-[0_14px_30px_-18px_rgb(var(--edgeever-brand-rgb)/0.85)] transition hover:-translate-y-0.5 hover:bg-brand-hover"
          href={copy.manualGuideHref}>
          {copy.manualGuide}
          <Icon class="h-5 w-5" name="bx:bx-right-arrow-alt" />
        </a>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  const copyTextToClipboard = async (text) => {
    if (navigator.clipboard && window.isSecureContext) {
      await navigator.clipboard.writeText(text);
      return;
    }

    const textarea = document.createElement("textarea");
    textarea.value = text;
    textarea.setAttribute("readonly", "");
    textarea.style.position = "fixed";
    textarea.style.left = "-9999px";
    textarea.style.top = "0";
    document.body.appendChild(textarea);
    textarea.focus();
    textarea.select();

    const copied = document.execCommand("copy");
    document.body.removeChild(textarea);

    if (!copied) {
      throw new Error("Copy command failed");
    }
  };

  const initAgentInstallTabs = () => {
    document.querySelectorAll("[data-agent-install-tabs]").forEach((root) => {
      if (root.getAttribute("data-agent-install-ready") === "true") return;
      root.setAttribute("data-agent-install-ready", "true");

      const tabs = Array.from(root.querySelectorAll("[data-tab-target]"));
      const panels = Array.from(root.querySelectorAll("[data-tab-panel]"));

      tabs.forEach((tab) => {
        tab.addEventListener("click", () => {
          const target = tab.getAttribute("data-tab-target");

          tabs.forEach((item) => {
            const isActive = item === tab;
            item.setAttribute("aria-selected", String(isActive));
            item.classList.toggle("active", isActive);
            item.classList.toggle("text-brand", isActive);
            item.classList.toggle("text-slate-500", !isActive);
          });

          panels.forEach((panel) => {
            panel.classList.toggle("hidden", panel.getAttribute("data-tab-panel") !== target);
          });
        });
      });

      root.querySelectorAll("[data-copy-text]").forEach((button) => {
        button.addEventListener("click", async () => {
          const text = button.getAttribute("data-copy-text") || "";
          const label = button.querySelector("[data-copy-label]");

          const defaultLabel = button.getAttribute("data-copy-default") || "Copy";
          const copyingLabel = button.getAttribute("data-copy-copying") || "Copying...";
          const copiedLabel = button.getAttribute("data-copy-copied") || "Copied";
          const failedLabel = button.getAttribute("data-copy-failed") || "Copy failed";

          if (label) label.textContent = copyingLabel;

          try {
            await copyTextToClipboard(text);
            if (label) label.textContent = copiedLabel;
            window.setTimeout(() => {
              if (label) label.textContent = defaultLabel;
            }, 1600);
          } catch {
            if (label) label.textContent = failedLabel;
          }
        });
      });
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initAgentInstallTabs);
  } else {
    initAgentInstallTabs();
  }
</script>

<style>
  .agent-install-tab.active::after {
    position: absolute;
    right: 0;
    bottom: -1px;
    left: 0;
    height: 3px;
    border-radius: 999px;
    background: var(--color-brand);
    content: "";
  }
</style>
